# =============================================================================
# Carrier Sales — Environment Configuration
#
# Copy this file to `.env` at the repo root. Both backend and dashboard read it.
#   cp .env.example .env
#
# Only the variables marked REQUIRED need a value to run. The rest have safe
# defaults baked into the code.
# =============================================================================


# ─── Runtime stage ────────────────────────────────────────────────────────────
# LOCAL | DEV | STAGING | PROD
# In LOCAL with API_KEY empty, the backend bypasses auth so you can curl freely
# during dev. Set to PROD on Railway and ALWAYS set API_KEY there.
ENV_STAGE_NAME=LOCAL


# ─── Backend auth ─────────────────────────────────────────────────────────────
# REQUIRED outside LOCAL. Every endpoint expects this in the X-API-Key header.
# Generate with:  openssl rand -hex 32
API_KEY=


# ─── FMCSA carrier verification ──────────────────────────────────────────────
# Get your WebKey here: https://mobile.fmcsa.dot.gov/QCDevsite/
#
# Two operating modes:
#   1. Mock mode (default for local dev): USE_FMCSA_MOCK=true
#        - Returns canned data. Even MC numbers → eligible, odd → not eligible.
#        - No WebKey needed. Use this until your real key arrives.
#   2. Live mode: USE_FMCSA_MOCK=false  +  FMCSA_WEBKEY filled in
#        - Hits the real FMCSA QCMobile API.
USE_FMCSA_MOCK=true
FMCSA_WEBKEY=


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the backend from a browser.
# Add your deployed dashboard URL here for production.
CORS_ORIGINS=http://localhost:3000


# ─── Database (optional — defaults are fine for the POC) ─────────────────────
# Postgres + asyncpg. Locally, `docker compose up -d postgres` exposes 5432.
# On Railway, set this to the Postgres add-on's internal URL.
# DATABASE_URL=postgresql+asyncpg://carrier:carrier@localhost:5432/carrier_sales
# LOADS_SEED_PATH=src/app/features/inbound_carrier_sales/seeds/loads.json


# ─── Dashboard ────────────────────────────────────────────────────────────────
# Base URL the Next.js app calls at BUILD time (NEXT_PUBLIC_* are baked in).
#   - Local:   http://localhost:8000
#   - Railway: http://<backend-service-name>.railway.internal:8000   (free internal networking)
NEXT_PUBLIC_API_URL=http://localhost:8000
