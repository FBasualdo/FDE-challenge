#!/usr/bin/env bash
# pre-commit — backend: isort + black + ruff; dashboard: tsc + lint.
# Each tool runs only on the files staged for THIS commit, then re-stages
# the formatter outputs so the commit captures the polished files.
set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

ROOT="$(git rev-parse --show-toplevel)"
STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -z "$STAGED" ] && exit 0

PY=$(echo "$STAGED" | grep -E '^backend/.*\.py$' || true)
TS=$(echo "$STAGED" | grep -E '^dashboard/.*\.(ts|tsx)$' || true)

if [ -z "$PY" ] && [ -z "$TS" ]; then
  echo -e "${DIM}[pre-commit] no backend/dashboard changes — skipped${RESET}"
  exit 0
fi

run_step() {
  local label="$1"; shift
  local out
  if out=$("$@" 2>&1); then
    echo -e "  ${GREEN}✓${RESET} ${label}"
  else
    echo -e "  ${RED}✗${RESET} ${BOLD}${label}${RESET}"
    echo "$out" | sed 's/^/      /'
    exit 1
  fi
}

# ─── Backend ──────────────────────────────────────────────────────────────────
if [ -n "$PY" ]; then
  cd "$ROOT/backend"
  REL=$(echo "$PY" | sed 's|^backend/||')
  # isort first (orders imports), then black (reformats body), then ruff
  # (catches remaining lint). Order matters: black would otherwise undo
  # isort's grouping decisions.
  run_step "isort"           uv run isort $REL
  run_step "black"           uv run black --quiet $REL
  run_step "ruff check --fix" uv run ruff check --fix $REL
  cd "$ROOT"
  # Re-stage formatter output so the commit captures it.
  echo "$PY" | xargs git add
fi

# ─── Dashboard ────────────────────────────────────────────────────────────────
if [ -n "$TS" ]; then
  cd "$ROOT/dashboard"
  run_step "tsc --noEmit" npx tsc --noEmit
  run_step "next lint"    npx next lint --quiet
  cd "$ROOT"
fi
